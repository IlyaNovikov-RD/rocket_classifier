# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/

# ── Environments ──────────────────────────────────────────────────────────────
.venv/
.env

# ── Lock files (uv.lock is tracked; poetry.lock is not) ──────────────────────
poetry.lock

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Data (large CSVs, not tracked) ───────────────────────────────────────────
data/

# ── Feature caches (large Parquet files, regenerated from data/) ──────────────
cache/
*.parquet

# ── Model artifacts (served from latest GitHub Release) ──────────────────────
# Download with: make download-weights
weights/

# ── Pipeline outputs ──────────────────────────────────────────────────────────
outputs/

# ── Local experiment artifacts ────────────────────────────────────────────────
colab_brute_force_results/

# ── Personal / IDE files ──────────────────────────────────────────────────────
.claude/
*.pdf
